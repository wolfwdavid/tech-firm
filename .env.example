# Crystarium — Manager (React, /src) — environment variables
#
# Copy to .env.local and fill the values Claude-A drops into issue #1.
# .env.local is .gitignored. NEVER commit real keys.

# ── Supabase (shared with the SvelteKit storefront in /web) ─────────────────
# Claude-A provisions the project; both anon keys live in front-end .env.local.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Feature flags ──────────────────────────────────────────────────────────
# When true, agent chat calls /api/chat (live Claude API).
# When false (default), uses the canned-response keyword matcher shipped in v1.
VITE_LIVE_AGENTS=false

# When true (default IF Supabase URL is set), Crystarium subscribes to remote
# automation_events instead of the local 15-22s timer driver.
# Force off to demo offline.
VITE_REMOTE_AUTOMATIONS=true

# ── Live agent API endpoint (only used when VITE_LIVE_AGENTS=true) ─────────
# Either Claude-A's SvelteKit `/web` deployment, or a local Vercel function.
# Leave blank to default to same-origin /api/chat.
VITE_AGENT_API_URL=
