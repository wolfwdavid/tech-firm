# Crystarium v2 environment contract.
# Copy this to `.env` (project root) and `.env.local` (web/) and fill values.
# Anon keys are safe to commit — service keys are NOT.

# -----------------------------------------------------------------------------
# Supabase — shared between React Crystarium (/src) and SvelteKit storefront (/web)
# Same values, two prefixes because Vite needs VITE_* and SvelteKit needs PUBLIC_*.
# -----------------------------------------------------------------------------
# React Crystarium (Vite client)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# SvelteKit storefront (SvelteKit reads $env/static/public)
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# -----------------------------------------------------------------------------
# Anthropic — server-side only, used by /api/chat (Claude-B's Manager endpoint)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=<server-side-key>

# -----------------------------------------------------------------------------
# Resend — server-side only, used by storefront /api/welcome route
# -----------------------------------------------------------------------------
RESEND_API_KEY=<server-side-key>
RESEND_FROM_EMAIL=Decisions <hello@yourdomain.com>

# -----------------------------------------------------------------------------
# Agent live/mocked toggle (React Crystarium)
# Set to "true" to call live /api/chat; otherwise mocked canned responses.
# -----------------------------------------------------------------------------
VITE_LIVE_AGENTS=false
# Optional override for the live endpoint (defaults to /api/chat).
# VITE_AGENT_API_URL=https://<vercel-deploy>.vercel.app/api/chat
